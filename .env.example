# Required: https://console.groq.com/keys
GROQ_API_KEY=

# Optional: defaults to llama-3.3-70b-versatile — see https://console.groq.com/docs/models
# GROQ_MODEL=llama-3.3-70b-versatile

# Optional: on HTTP 429, retry the same request once with this model (must differ from the primary model)
# GROQ_FALLBACK_MODEL=llama-3.1-8b-instant

# Optional: require Authorization: Bearer <token> on /chat and /v1/* (not /health). OpenAI client: api_key="<token>"
# CHATTY_API_KEY=

# Optional: Tavily web search when web_search=true or X-Chatty-Web-Search header — https://tavily.com
# TAVILY_API_KEY=
# TAVILY_MAX_RESULTS=5
# TAVILY_SEARCH_DEPTH=basic
